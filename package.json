{
  "name": "@alexgorbatchev/pi-agentation",
  "version": "3.0.0",
  "description": "pi extension launcher for the Agentation fix loop",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "agentation"
  ],
  "bin": {
    "pi-agentation": "./bin/pi-agentation"
  },
  "pi": {
    "extensions": [
      "./agentation.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "agentation.ts",
    "README.md",
    "bin/pi-agentation",
    "skills/agentation-fix-loop/SKILL.md"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.61.0"
  },
  "scripts": {
    "check": "npm run verify:pi-load",
    "verify:pi-load": "PI_OFFLINE=1 pi --no-extensions -e ./agentation.ts --list-models > /dev/null"
  }
}
